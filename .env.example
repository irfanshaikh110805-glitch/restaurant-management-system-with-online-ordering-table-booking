# ============================================
# SECURITY WARNING: NEVER COMMIT THIS FILE WITH REAL VALUES!
# ============================================
# 
# This is a template file. Copy it to .env and fill in your actual values.
# The .env file is gitignored and should NEVER be committed to version control.
#
# IMPORTANT SECURITY NOTES:
# 1. Use different API keys for development, staging, and production
# 2. Rotate API keys every 90 days
# 3. Never expose secret keys client-side (only use VITE_ prefix for public keys)
# 4. Enable Row Level Security (RLS) in Supabase for all tables
# 5. Monitor API key usage for unusual activity
# 6. Restrict Supabase anon key permissions using RLS policies
#
# For more information, see SECURITY.md
# ============================================

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe Configuration (Optional - for payment processing)
# Get this from: https://dashboard.stripe.com/apikeys
# NOTE: Use PUBLISHABLE key only (starts with pk_)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Razorpay Configuration (for online payments)
# Get these from: https://dashboard.razorpay.com/app/keys
# NOTE: Use TEST keys for development (starts with rzp_test_)
# Use LIVE keys for production (starts with rzp_live_)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
# WARNING: Never expose the secret key in frontend! Keep it server-side only
# RAZORPAY_KEY_SECRET=your_secret_key_here

# Google Maps API (Optional - for location features)
# Get this from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Analytics (Optional)
VITE_ENABLE_ANALYTICS=false
VITE_GA_MEASUREMENT_ID=your_google_analytics_measurement_id
VITE_FB_PIXEL_ID=your_facebook_pixel_id

# Application Settings
VITE_APP_URL=http://localhost:5174
VITE_ENABLE_PWA=true

# Error Monitoring (Optional - Sentry)
VITE_SENTRY_DSN=your_sentry_dsn
VITE_ERROR_ENDPOINT=your_custom_error_endpoint

# ============================================
# SETUP INSTRUCTIONS:
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual API keys in the .env file
# 3. Verify .env is in .gitignore
# 4. Enable RLS on all Supabase tables
# 5. Test your configuration
# 6. Never commit the .env file!
# ============================================
