{
  "name": "spice-haven",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "audit": "node scripts/performance-audit.js",
    "audit:prod": "npm run build && npm run preview & sleep 5 && node scripts/performance-audit.js http://localhost:4173",
    "test": "node scripts/full-stack-test.js",
    "test:demo": "node scripts/full-stack-test-demo.js",
    "test:verbose": "node scripts/full-stack-test.js --verbose",
    "test:mobile": "node scripts/mobile-test.js",
    "analyze": "vite build --mode analyze",
    "optimize:images": "node scripts/optimize-images.js",
    "perf:boost": "npm run build && node scripts/performance-boost.js",
    "perf:100": "node scripts/performance-100.js",
    "lint": "eslint src --ext .js,.jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "check-deployment": "node scripts/check-deployment.js",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,md}\"",
    "docker:build": "docker build -t hotel-everest-restaurant .",
    "docker:run": "docker run -p 80:80 hotel-everest-restaurant",
    "docker:compose": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "security:audit": "npm audit --audit-level=moderate",
    "verify:deployment": "node scripts/verify-deployment.js",
    "prepare": "node -e \"try { require('husky').install() } catch (e) {}\""
  },
  "dependencies": {
    "@stripe/stripe-js": "^2.4.0",
    "@supabase/supabase-js": "^2.39.0",
    "date-fns": "^3.3.0",
    "date-fns-tz": "^2.0.0",
    "framer-motion": "^12.34.0",
    "leaflet": "^1.9.4",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.0.1",
    "react-image-lightbox": "^5.1.4",
    "react-leaflet": "^4.2.1",
    "react-qr-code": "^2.0.12",
    "react-router-dom": "^6.21.0",
    "react-share": "^5.0.3",
    "recharts": "^2.10.0",
    "swiper": "^12.1.2",
    "web-vitals": "^3.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^10.0.1",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "globals": "^17.3.0",
    "prettier": "^3.2.5",
    "terser": "^5.36.0",
    "vite": "^7.3.1",
    "vite-plugin-compression2": "^2.4.0"
  }
}
